# Hyperedit / ClipWise — environment template
# Copy to `.env` (gitignored) and fill real values. NEVER commit `.env`.
#
# ERP screenshot/recording scripts (scripts/capture_erp_screenshots.py,
# scripts/record_erp_screens.py, scripts/record_extra_screens.py) read the
# login credentials from the environment — they will refuse to run if unset.

# Admin login for the ERP screenshot/recording automation.
ERP_LOGIN_EMAIL=
ERP_LOGIN_PASSWORD=
